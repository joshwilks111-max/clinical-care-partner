# Per-repo .gitignore — layers on top of ~/.config/git/ignore (the global).
# The global already covers: secrets (.env*, *.pem, *.key, *credentials*, *secret*),
# OS noise, editor dirs, node_modules, dist/build, Python caches, deploy state, logs.
# Only add what's SPECIFIC to this assignment below.

# -------- Assignment inputs / sensitive material --------
# Keep the brief and any provided sample/clinical data out of git by default.
# Un-ignore specific safe files with `!path` if you decide they should be tracked.
/assignment/
/brief/
/data/
/samples/
*.local.md

# -------- Scratch / working notes --------
/scratch/
/notes/
TODO.local.md

# -------- Eval (promptfoo) generated artefacts --------
# The committed eval suite is promptfoo.yaml + tests/evals/*.ts. These are
# per-run generated outputs (kept out of git). The reviewer-facing capture lives
# at tests/evals/sample-output.txt, which IS committed.
/.promptfoo/
.promptfoo/
/tests/evals/usage-totals.json
/tests/evals/_*.json

# -------- Stack-specific: Next.js + TypeScript --------
# node_modules/ is covered by the global; these are Next-specific build/gen artefacts
# the global misses.
/.next/
/out/
next-env.d.ts
*.tsbuildinfo
/coverage/
.vercel
